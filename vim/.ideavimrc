""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
""" Basic configuration
""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""

"" global
set nu
set nowrap
set encoding=utf-8
set hlsearch
set nocompatible
set backspace=indent,eol,start
set hidden

"" remap C-p to C-i, because C-i sometimes override by other shortcuts
nnoremap <C-p> <C-i>

"" split window
nnoremap <Space>sv :vsplit<Enter>
nnoremap <Space>sh :split<Enter>

"" vimdiff
nnoremap <Space>ds :diffthis<Enter>

"" filetype extension
"" java
au BufNewFile,BufRead *.java,*.jav,*.aidl setf java

"" quick edit .vimrc
map <Leader><F2> :e $MYVIMRC<CR>
"" quick reload .vimrc
nnoremap <leader>sv :source $MYVIMRC<CR>

"" change buffer
nnoremap <Leader>[ :bp<Enter>
nnoremap <Leader>] :bn<Enter>

"" Disable swap
set noswapfile

"" enable clipboard
inoremap <C-v> <ESC>"+pa
vnoremap <C-c> "+y
vnoremap <C-d> "+d

"" move
nnoremap mb ^
nnoremap me $
vnoremap mb ^
vnoremap me $

"" page up/down and center cursor
nnoremap mu <C-b>M
nnoremap md <C-f>M
vnoremap mu <C-b>M
vnoremap md <C-f>M

"" Switch to alternate file
nnoremap ma :A<CR>

"" Write file
nnoremap mw :w<CR>

"" Reload file
nnoremap mr :e<CR>

"" Quit
nnoremap mq :q<CR>

"" Quit all
nnoremap mx :qa!<CR>

"" Clear search highlight
nnoremap mn :noh<CR>

"" Alt + * move line
"" http://vim.wikia.com/wiki/Moving_lines_up_or_down
nnoremap ∆ :m .+1<CR>==
nnoremap ˚ :m .-2<CR>==
inoremap ∆ <Esc>:m .+1<CR>==gi
inoremap ˚ <Esc>:m .-2<CR>==gi
vnoremap ∆ :m '>+1<CR>gv=gv
vnoremap ˚ :m '<-2<CR>gv=gv

"" tab spaces
set tabstop=4
set expandtab
set shiftwidth=4

augroup FileTypeIndent
    autocmd!
    autocmd FileType javascript,typescript,yaml,yml,json setlocal tabstop=2 shiftwidth=2
    autocmd FileType python,dockerfile setlocal tabstop=4 shiftwidth=4
augroup END

"" Shifting blocks visually
nnoremap > >>
nnoremap < <<
vnoremap > >gv
vnoremap < <gv

"" resize window
map <Leader>= :vertical resize +10<Enter>
map <Leader>- :vertical resize -10<Enter>
map <Leader>. :resize +10<Enter>
map <Leader>, :resize -10<Enter>

"" highlight current line and column
au WinLeave * set nocursorline nocursorcolumn
au WinEnter * set cursorline cursorcolumn
set cursorline cursorcolumn

augroup QuickFixPosition
    autocmd!
    autocmd FileType qf wincmd J
augroup END

"" close quickfix by type 'q' and return the cursor to the editor window
autocmd FileType qf nnoremap <buffer>q :cclose<CR>:wincmd p<CR>

""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
""" ideavim configuration
""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""

nnoremap <Space>e :action RecentFiles<CR>
nnoremap <Space>ff :action SearchEverywhere<CR>
nnoremap <Space>gc :action ShowUsages<CR>
nnoremap <Leader>gs :action VersionControlsGroup<CR>
nnoremap <Leader>gb :action Annotate<CR>
nnoremap <F2> :action ActivateTerminalToolWindow<CR>
nnoremap <C-r> :action Run<CR>
nnoremap <C-e> :action Debug<CR>
nnoremap == :action ReformatCode<CR>
"" Unmap <CR> to prevent any accidental override in insert mode
iunmap <CR>
